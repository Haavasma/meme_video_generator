    "remotion": "4.0.315",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "6.5.0",
    "@testing-library/react": "16.1.0",
    "@types/node": "22.9.0",
    "@types/react": "19.0.1",
    "@types/react-dom": "19.0.1",
    "@vitejs/plugin-react": "4.3.4",
    "@vitest/coverage-v8": "^2.1.8",
    "jsdom": "25.0.1",
    "typescript": "5.7.2",
    "vitest": "2.1.8"
